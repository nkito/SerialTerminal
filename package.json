{
  "name": "serial-terminal",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "start:electron": "electron .",
    "start:electron:built": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir --win",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "jp.example.serialterminal",
    "productName": "SerialTerminal",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon/serialterm.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon/serialterm.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "iconv-lite": "^0.7.2",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.4"
  }
}
